{
    "name": "nmbrthirteen/aggregate-it",
    "description": "An SEO content engine that uses RSS as raw material - imports feeds, faithfully rewrites with AI, deduplicates into living topic pages, and auto-builds entity hubs.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Nika Siradze",
            "homepage": "https://nikusha.com"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "AggregateIt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AggregateIt\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
